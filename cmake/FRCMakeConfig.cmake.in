@PACKAGE_INIT@

include(CMakeFindDependencyMacro)

list(APPEND CMAKE_MODULES_PATH "${CMAKE_CURRENT_LIST_DIR}/cmake")

foreach(comp ${FRCMake_FIND_COMPONENTS})
    if(NOT TARGET FRCMake::${comp})
        set(FRCMake_NOT_FOUND_MESSAGE "FRCMake component ${comp} not found.")
        set(FRCMake_FOUND FALSE)
    endif()
endforeach()
